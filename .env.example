# Local development secrets for pi-harness-runtime maintainers.
#
# Copy to .env (which is gitignored) and fill in real values:
#   cp .env.example .env
#
# IMPORTANT: Rename `GITHUB_TOKEN` to something else (e.g. `GH_FG_PAT`)
# if you also use `gh auth login` locally, because `gh` CLI auto-detects
# any env var named GITHUB_TOKEN and uses it as the active auth —
# overriding your `gh auth login` OAuth token.

# --- GitHub: Fine-Grained Personal Access Token ---
# Source: https://github.com/settings/tokens?type=beta
# Required permissions for the `ManotLuijiu/pi-harness-runtime` repo:
#   - Contents: Read and write   (for `gh release create`, tag push)
#   - Metadata: Read-only        (auto-granted)
#   - Pull requests: Read and write  (optional, for PR-based release flow)
# Expiration: 90 days (recommended)
GITHUB_TOKEN="github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- npm: Granular Access Token (with 2FA bypass) ---
# Source: https://www.npmjs.com/settings/manotluijiu/tokens
# Required configuration:
#   - Packages and scopes: "Only this package" → "pi-harness-runtime"
#   - Permissions: Read and write
#   - 2FA: ✅ Bypass 2FA for this token
#
# USAGE NOTES:
#   - `npm publish` does NOT read the `NPM_TOKEN` env var — it reads
#     `~/.npmrc` first. To use this token, either:
#
#       a) write a project .npmrc (gitignored) containing:
#          //registry.npmjs.org/:_authToken=npm_xxxxxxxx
#
#       b) or pass via CLI:
#          NPM_CONFIG_USERCONFIG=/tmp/npmrc npm publish --access public
#
#   - In CI (.github/workflows/release.yml), the `NODE_AUTH_TOKEN`
#     env var is used (set automatically by actions/setup-node).
NPM_TOKEN="npm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- MiniMax Usage Auto-Fetch (optional) ---
# The harness auto-fetches MiniMax quota on turn_end for MiniMax models.
# It reads cookies from a Netscape-format cookie file. The DEFAULT path is:
#   ~/.config/minimax-cookies.txt
# which needs no env var. Override only if you keep the file elsewhere:
#
#   QUOTA_COOKIE_FILE=/absolute/path/to/platform.minimax.io_cookies.txt
#
# How to export cookies:
#   - Install "EditThisCookie" (or similar) Chrome extension
#   - Log in at https://platform.minimax.io, open the usage page
#   - Export → Netscape HTTP Cookie File → save to the path above
# The scraper prefers a direct API call (no browser) using these cookies,
# and falls back to a headless browser scrape if the API is unavailable.
# Cookies/`_token` JWT expire (~30-35 days) — re-export when that happens.
