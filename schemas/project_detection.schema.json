{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectDetectionResult",
  "type": "object",
  "required": [
    "project_type",
    "confidence",
    "signals",
    "recommended_seed_strategy",
    "recommended_e2e_strategy"
  ],
  "properties": {
    "project_type": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_seed_strategy": {
      "type": "string"
    },
    "recommended_e2e_strategy": {
      "type": "string"
    }
  }
}
