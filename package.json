{
  "name": "pi-harness-runtime",
  "version": "0.4.0",
  "description": "[BETA] Codex-style /usage status + autonomous coding harness for pi. Not production ready — expect breaking changes.",
  "type": "module",
  "workspaces": [
    "packages/provider-adapter-sdk",
    "packages/checkpoint",
    "packages/session",
    "packages/observability",
    "packages/code-review",
    "packages/code-generation",
    "packages/framework-detector",
    "packages/test-data-generator",
    "packages/framework-plugin-sdk"
  ],
  "scripts": {
    "test": "bun test",
    "test:packages": "bun test packages/*/test/*.test.ts",
    "build": "bun run build:all",
    "build:all": "bun run build:provider-adapter-sdk && bun run build:checkpoint && bun run build:session && bun run build:observability && bun run build:code-review && bun run build:code-generation && bun run build:framework-detector && bun run build:test-data-generator && bun run build:framework-plugin-sdk",
    "build:provider-adapter-sdk": "cd packages/provider-adapter-sdk && bun run build",
    "build:checkpoint": "cd packages/checkpoint && bun run build",
    "build:session": "cd packages/session && bun run build",
    "build:observability": "cd packages/observability && bun run build",
    "build:code-review": "cd packages/code-review && bun run build",
    "build:code-generation": "cd packages/code-generation && bun run build",
    "build:framework-detector": "cd packages/framework-detector && bun run build",
    "build:test-data-generator": "cd packages/test-data-generator && bun run build",
    "build:framework-plugin-sdk": "cd packages/framework-plugin-sdk && bun run build",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:dry-run": "standard-version --dry-run",
    "auth:minimax": "bun packages/auth/src/run-minimax-auth.ts auth",
    "auth:minimax:check": "bun packages/auth/src/run-minimax-auth.ts check",
    "auth:minimax:scrape": "bun packages/auth/src/run-minimax-auth.ts scrape"
  },
  "bin": {
    "harness-auth": "packages/auth/src/run-minimax-auth.ts"
  },
  "files": [
    "index.ts",
    "tracker.ts",
    "mirror.ts",
    "windows.ts",
    "renderer.ts",
    "sync-form.ts",
    "cli.ts",
    "harness",
    "packages",
    "skills",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "usage",
    "tokens",
    "cost",
    "codex"
  ],
  "author": "MooCoding",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ManotLuijiu/pi-harness-runtime.git"
  },
  "bugs": {
    "url": "https://github.com/ManotLuijiu/pi-harness-runtime/issues"
  },
  "homepage": "https://github.com/ManotLuijiu/pi-harness-runtime#readme",
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "playwright": "^1.61.1",
    "standard-version": "^9.5.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "deepagents": "^1.10.5",
    "pi-harness-runtime": "^0.3.2-beta.1"
  }
}
